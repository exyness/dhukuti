# Dhukuti web environment
# NEXT_PUBLIC_* values are browser-safe. Every other value is server-only.
# Do not commit your .env.local file or share the server-only values.

# Local Supabase from `supabase start`
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_with_local_key
# SUPABASE_SECRET_KEY=sb_secret_replace_with_local_key

# Hosted Supabase — browser URL/key, then the server credential
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_with_your_key
SUPABASE_SECRET_KEY=sb_secret_replace_with_your_key

# Server-only Helius indexer configuration
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=replace-with-your-key
HELIUS_WEBHOOK_SECRET=replace-with-a-long-random-secret
INDEXER_ADMIN_SECRET=replace-with-a-different-long-random-secret

# Public Solana RPC
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

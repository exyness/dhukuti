# Dhukuti web environment
#
# Default to local Supabase for development. To use hosted Supabase, comment the
# local block and uncomment the hosted block below.

# Local Supabase from `supabase start`
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH
SUPABASE_SECRET_KEY=<local-supabase-secret-key-from-supabase-status>

# Hosted Supabase
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_with_hosted_key
# SUPABASE_SECRET_KEY=<hosted-supabase-secret-key>

# Solana
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Server-only indexer secrets. Never prefix these with NEXT_PUBLIC_.
HELIUS_API_KEY=
# HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=replace-with-helius-api-key
HELIUS_WEBHOOK_SECRET=
INDEXER_ADMIN_SECRET=
